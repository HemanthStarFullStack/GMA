# ─── GMA environment ─────────────────────────────────────────────────────────
# Copy to .env (compose) or .env.local (next dev) and fill in.
# .env* is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (host) MongoDB or Atlas. In docker-compose this is built from the
# MONGO_* vars below; set it directly only for `next dev`.
MONGODB_URI=mongodb://admin:changeme@localhost:27017/gma?authSource=admin

# Used by docker-compose to provision the mongodb container + build MONGODB_URI.
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DB=gma

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate with:  npx auth secret
AUTH_SECRET=replace_with_generated_secret
# Public URL of the app (used for OAuth callbacks behind a proxy).
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI prediction (optional) ──────────────────────────────────────────────────
# Primary predictor. If unset, the app falls back to the local LLM, then a
# heuristic. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Local LLM fallback via Ollama (optional). Disable with LOCAL_LLM_ENABLED=false.
# In Docker, host Ollama is reachable at http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LOCAL_LLM_ENABLED=true

# ── Admin endpoints ───────────────────────────────────────────────────────────
# Required to use /api/admin/* (reset, refresh-durations, debug-gemini).
# If unset, those routes return 404. Send as the `x-admin-secret` header.
ADMIN_SECRET=
