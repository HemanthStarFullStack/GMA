# Caddy reverse proxy — automatic HTTPS for the public subdomain.
#
# Caddy obtains and renews a Let's Encrypt certificate for $APP_DOMAIN
# automatically, redirects HTTP→HTTPS, and proxies to the Next.js app
# container. Requires: DNS for $APP_DOMAIN -> this host, and ports 80+443
# reachable from the internet.

{
	# Email used for Let's Encrypt registration / expiry notices.
	email {$LETSENCRYPT_EMAIL}
}

{$APP_DOMAIN} {
	encode zstd gzip
	reverse_proxy app:3000 {
		# Forward the real client info so NextAuth/Next sees the public URL.
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
